{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "主窗口基础能力：路径、事件、窗口、资源、菜单、托盘，以及文件打开/保存对话框",
  "platforms": [
    "windows",
    "macOS",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:window:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "core:path:default",
    "core:window:allow-set-title",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
